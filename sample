
charAt

public class Main {
  public static void main(String[] args) {
    String myStr = "Oluyemi";
    char result = myStr.charAt(0);
    System.out.println(result);
  }
}



public class Main {
  public static void main(String[] args) {
    String myStr = "Oluyemi";
    
    for(int index = 0; index < myStr.length(); index++){
       char result = myStr.charAt(index);
       System.out.println(result);
    }
  }
}

